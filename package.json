{
  "name": "n8n-self-healing",
  "version": "1.0.0",
  "private": true,
  "description": "Self-healing n8n workflows built with n8nac",
  "scripts": {
    "setup:n8n": "bash scripts/init-n8n.sh",
    "check-secrets": "bash scripts/check-secrets.sh",
    "check-secrets:staged": "bash scripts/check-secrets.sh --staged",
    "check-secrets:strict": "bash scripts/check-secrets.sh --strict",
    "demo:errors": "bash scripts/demo-all-errors.sh",
    "new-workflow": "bash scripts/new-workflow.sh",
    "validate": "jq . workflow/workflow.json > /dev/null && echo 'Workflow JSON is valid'",
    "validate:workflows": "bash scripts/validate-workflows.sh"
  },
  "license": "MIT",
  "devDependencies": {
    "n8nac": "^1.6.2"
  }
}
